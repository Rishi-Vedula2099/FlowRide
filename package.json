{
  "name": "flowride",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered ride-sharing platform",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:ai": "cd ai-service && uvicorn main:app --reload --port 8000",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npx tsc",
    "db:generate": "cd backend && npx prisma generate",
    "db:push": "cd backend && npx prisma db push",
    "db:seed": "cd backend && npx prisma db seed",
    "db:studio": "cd backend && npx prisma studio"
  }
}
